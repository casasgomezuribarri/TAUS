Package: TAUS
Title: Target-Age Unified Survival
Version: 0.1.0
Authors@R: c(
    person("Iván", "Casas Gomez-Uribarri", email = "i.casas-gomez-uribarri.1@research.gla.ac.uk", role = c("aut", "cre")),
    person("Simon A.", "Babayan", role = "aut"),
    person("Fredros", "Okumu", role = "aut"),
    person("Francesco", "Baldini", role = "aut"),
    person("Mauro", "Pazmiño Betancourth", role = "aut")
